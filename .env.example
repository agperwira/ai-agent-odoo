# Odoo Connection
ODOO_URL=http://127.0.0.1:8069
ODOO_DB=nama_database
ODOO_USER=user@email.com
ODOO_PASS=password_odoo

# SumoPod AI
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=https://ai.sumopod.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT=60
AI_MAX_RETRIES=3

# Telegram Bot
TELEGRAM_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Akses kontrol — pisah dengan koma, tanpa spasi
# Cara cari Telegram User ID: chat ke @userinfobot di Telegram
TELEGRAM_ADMIN_IDS=111111111
TELEGRAM_ALLOWED_IDS=222222222,333333333

# Rate limiting (detik antar request per user)
RATE_LIMIT_SECONDS=3
